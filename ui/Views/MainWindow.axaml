<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:BiliSearch.UI.ViewModels"
        xmlns:m="using:BiliSearch.UI.Models"
        x:Class="BiliSearch.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="bili-7UID-search"
        Width="820" Height="700"
        MinWidth="660" MinHeight="540"
        Background="#faf9f7">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" Margin="16">

        <!-- Tab strip -->
        <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedTab}"
                    Background="Transparent" Padding="0">
            <TabItem Header="按后缀扫描">
                <StackPanel Spacing="4" Margin="0,8,0,0">
                    <TextBlock Text="四位数后缀" FontSize="12" Foreground="#6b6b6b"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox Text="{Binding Suffix}" Width="120"
                                 FontFamily="Consolas" FontSize="14"
                                 Watermark="如 1314" MaxLength="4"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="按回文扫描">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel Spacing="4">
                            <TextBlock Text="位数" FontSize="12" Foreground="#6b6b6b"/>
                            <TextBox Text="{Binding Digits}" Width="60"
                                     FontFamily="Consolas" FontSize="14" Watermark="7"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="UID 下限" FontSize="12" Foreground="#6b6b6b"/>
                            <TextBox Text="{Binding UidLo}" Width="160"
                                     FontFamily="Consolas" FontSize="14" Watermark="可选"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="UID 上限" FontSize="12" Foreground="#6b6b6b"/>
                            <TextBox Text="{Binding UidHi}" Width="160"
                                     FontFamily="Consolas" FontSize="14" Watermark="可选"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Proxy row -->
        <Border Grid.Row="1" Margin="0,8,0,0" Padding="0,4">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="代理" VerticalAlignment="Center" FontSize="13" Foreground="#6b6b6b"/>
                <RadioButton Content="直连" IsChecked="{Binding ProxyNone}" GroupName="Proxy"/>
                <RadioButton Content="手动" IsChecked="{Binding ProxyManual}" GroupName="Proxy"/>
                <RadioButton Content="代理池" IsChecked="{Binding ProxyPool}" GroupName="Proxy"/>
                <TextBox Text="{Binding ProxyAddress}" Width="220"
                         FontFamily="Consolas" FontSize="12"
                         Watermark="http://host:port"
                         IsEnabled="{Binding IsManualProxy}"/>
            </StackPanel>
        </Border>

        <!-- Buttons + status -->
        <Border Grid.Row="2" Margin="0,10,0,0">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Grid.Column="0" Content="开始扫描"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding CanStart}"
                        Background="#c96442" Foreground="White"
                        FontWeight="Bold" Padding="16,6" CornerRadius="4"/>
                <Button Grid.Column="1" Content="停止" Margin="8,0,0,0"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding CanStop}"
                        Background="#c94242" Foreground="White"
                        FontWeight="Bold" Padding="16,6" CornerRadius="4"/>
                <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                           VerticalAlignment="Center" FontSize="13" Foreground="#6b6b6b"/>
            </Grid>
        </Border>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="3" Margin="0,8,0,0"
                     Value="{Binding Progress}" Maximum="100"
                     Height="6" CornerRadius="3"
                     Foreground="#c96442" Background="#e8e4df"/>

        <!-- Bottom: log + results -->
        <Grid Grid.Row="4" RowDefinitions="*,8,*" Margin="0,8,0,0">

            <!-- Log panel -->
            <Border Grid.Row="0" Background="#1e1e1e" CornerRadius="6" Padding="8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LogText}"
                               FontFamily="Consolas" FontSize="12"
                               Foreground="#d4d4d4"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>

            <!-- Grip -->
            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch"/>

            <!-- Results table (simple Grid-based, no DataGrid package needed) -->
            <Border Grid.Row="2" BorderBrush="#e8e4df" BorderThickness="1" CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Grid.Row="0" Background="#f0eeea" Padding="8,6">
                        <Grid ColumnDefinitions="140,*,100">
                            <TextBlock Grid.Column="0" Text="UID"
                                       FontWeight="Bold" FontSize="12" Foreground="#6b6b6b"/>
                            <TextBlock Grid.Column="1" Text="昵称"
                                       FontWeight="Bold" FontSize="12" Foreground="#6b6b6b"/>
                            <TextBlock Grid.Column="2" Text="状态"
                                       FontWeight="Bold" FontSize="12" Foreground="#6b6b6b"/>
                        </Grid>
                    </Border>
                    <!-- Rows -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:ScanResult">
                                    <Border Padding="8,4" BorderBrush="#f0eeea" BorderThickness="0,0,0,1">
                                        <Grid ColumnDefinitions="140,*,100">
                                            <TextBlock Grid.Column="0" Text="{Binding Uid}"
                                                       FontFamily="Consolas" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Nickname}"
                                                       FontSize="12"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Status}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#2d7a4f"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
